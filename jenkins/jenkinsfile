pipeline{
    agent any
    tools {
        maven 'Mymaven'
    }
    stages{
        stage('checkout'){
            steps{
                git 'https://github.com/chulliyan/DevOpsCodeDemo.git'
            }
        }
        stage('compile'){
            steps{
                sh 'mvn clean compile'
            }
        }
        stage('parallel Test & Analysis'){
            parallel{
                stage('Unit Test'){
                    steps{
                        sh 'mvn test'
                    }
                }
                stage('integration Test'){
                    steps{
                        sh 'mvn verify'
                    }
                }
                stage('static code analysis'){
                    steps{
                        sh 'mvn pmd:pmd'
                    }
                }
            }
        }
    }
}
