pipeline{
    agent any
    tools {
        maven 'Mymaven'
    }
    stages{
        stage('checkout'){
            steps{
                git 'https://github.com/chulliyan/DevOpsCodeDemo.git'
            }
        }
        stage('compile'){
            steps{
                sh 'mvn clean compile'
            }
        }
        stage('parallel Test & Analysis'){
            parallel{
                stage('Unit Test'){
                    steps{
                        sh 'mvn test'
                    }
                    post {
                        always {
                            junit '**/target/surefire-reports/*.xml'
                        }
                    }
                }
                stage('integration Test'){
                    steps{
                        sh 'mvn verify'
                    }
                    post {
                        always {
                            junit '**/target/failsafe-reports/*.xml'
                            allow emptyResults: true
                        }
                    }
                }
                stage('static code analysis'){
                    steps{
                        sh 'mvn pmd:pmd'
                    }
                }
            }
        }
        stage('package'){
            steps{
                sh 'mvn package'
            }
            post {
                always {
                    archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
                }
            }
        }
    }
}
